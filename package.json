{
  "name": "universal-macro-recorder",
  "version": "0.1.0",
  "description": "通用键鼠录制回放工具",
  "main": "src/main.js",
  "author": "BossAutomation",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "local.universal-macro-recorder",
    "productName": "UniversalMacroRecorder",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "engine/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
